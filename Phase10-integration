// ── 6. Manual scraping from admin (no Edge Function required) ─────────
//
// The "Run now" button in /admin/scraping/page.tsx calls triggerScrapeRun()
// which runs runScrapingPass() directly inside Next.js server actions.
// This works for ad-hoc runs during development/testing without deploying
// the Edge Function. Note: on Vercel, server functions have a 60s timeout,
// so scraping many sources may need to be done source-by-source via
// the source checkbox UI.


// ── 7. How the pipeline works end-to-end ─────────────────────────────
//
//  ┌─────────────────────────────────────────────────┐
//  │  Scheduled Edge Function (every 6 hours)        │
//  │  OR Manual admin trigger                        │
//  └──────────────────┬──────────────────────────────┘
//                     │ for each active scrape_source
//                     ▼
//  ┌─────────────────────────────────────────────────┐
//  │  fetchPageText(url)                             │
//  │  → strips HTML, first 12,000 chars              │
//  └──────────────────┬──────────────────────────────┘
//                     ▼
//  ┌─────────────────────────────────────────────────┐
//  │  extractRecruitmentData(text, url, source)      │
//  │  → Claude parses into ExtractedRecruitment JSON │
//  │  → returns confidence score 0.0–1.0             │
//  └──────────────────┬──────────────────────────────┘
//                     ▼
//  ┌─────────────────────────────────────────────────┐
//  │  Deduplication check                            │
//  │  → similarity key: org + year + title words     │
//  │  → check against recruitments + queue tables    │
//  └──────────────────┬──────────────────────────────┘
//          ┌──────────┴───────────┐
//    duplicate                 new item
//          │                       │
//          ▼                       ▼
//  scrape_queue              scrape_queue
//  status=duplicate          status=pending (conf < 0.92)
//                            OR status=approved (conf ≥ 0.92
//                               + trusted source) → auto-promote
//                     ▼
//  ┌─────────────────────────────────────────────────┐
//  │  Admin reviews /admin/scraping/queue            │
//  │  → Approve → promoteToRecruitments()            │
//  │            → alertUsersForNewRecruitment()      │
//  │  → Reject  → status=rejected                   │
//  │  → Duplicate → status=duplicate                 │
//  └─────────────────────────────────────────────────┘
//                     ▼
//  ┌─────────────────────────────────────────────────┐
//  │  notification_alerts rows created               │
//  │  for all eligibility_results where is_eligible  │
//  │  → Users see bell badge in DashboardShell       │
//  │  → /dashboard/notifications full view           │
//  └─────────────────────────────────────────────────┘


// ── 8. Auto-approval thresholds ──────────────────────────────────────
//
// confidence >= 0.92 + source in trusted list → auto-approve + promote
// confidence  < 0.92 OR untrusted source     → goes to human review queue
//
// Trusted sources: UPSC, SSC, IBPS, RBI, SEBI, NABARD
// You can tune this in lib/scraping/runner.ts → isHighTrustSource()


