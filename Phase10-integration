// ── 3. Edge Function deploy ───────────────────────────────────────────
//
// Install Supabase CLI if not already:
//   npm install -g supabase
//
// Deploy the edge function:
//   supabase functions deploy scheduled-scraper --project-ref YOUR_PROJECT_REF
//
// Schedule it (every 6 hours):
//   supabase cron create scraper-cron "0 */6 * * *" \
//     --function scheduled-scraper \
//     --project-ref YOUR_PROJECT_REF
//
// The function uses these env vars (already in your Supabase project):
//   SUPABASE_URL
//   SUPABASE_SERVICE_ROLE_KEY
//   ANTHROPIC_API_KEY  ← add this in Supabase Dashboard → Edge Functions → Secrets


