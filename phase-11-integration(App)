# career-copilot-mobile/.env
# Copy to .env.local for local dev — never commit real values

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────────────────────
# PHASE 11: Mobile App — Integration Guide
# ─────────────────────────────────────────────────────────────────────

# ── 1. Folder structure ───────────────────────────────────────────────
#
# Create a sibling folder next to your Next.js project:
#
#   career-copilot/           ← existing Next.js web app
#   career-copilot-mobile/    ← new Expo mobile app
#     app/
#       _layout.tsx                   ← root layout, fonts, auth routing, push notif
#       (auth)/
#         _layout.tsx                 ← auth stack (create as simple Stack layout)
#         login.tsx                   ← login screen
#         signup.tsx                  ← (create, mirrors login but calls signUp)
#       (tabs)/
#         _layout.tsx                 ← tab bar navigator
#         index.tsx                   ← dashboard home
#         planner.tsx                 ← study planner
#         forum.tsx                   ← community forum
#         notifications.tsx           ← notification alerts
#         profile.tsx                 ← profile & settings
#       onboarding.tsx                ← (create: redirect to web for onboarding)
#     constants/
#       theme.ts                      ← design tokens
#     lib/
#       supabase.ts                   ← Supabase client with AsyncStorage
#       notifications.ts              ← push notif registration + scheduling
#     store/
#       auth.ts                       ← Zustand auth state
#     assets/
#       images/
#         icon.png                    ← 1024×1024 app icon (dark bg, gold wordmark)
#         splash.png                  ← splash screen
#         adaptive-icon.png           ← Android adaptive icon foreground
#         notification-icon.png       ← Android notification icon (white on transparent)
#     package.json
#     app.json
#     eas.json
#     tsconfig.json
#     .env

# ── 2. Initial setup ──────────────────────────────────────────────────
#
#   cd career-copilot-mobile
#   npm install -g eas-cli expo-cli
#   npm install                        # or: pnpm install
#   npx expo install                   # fixes any peer dep mismatches
#
#   # Install Google Fonts packages for Playfair + DM Sans + DM Mono
#   npx expo install @expo-google-fonts/playfair-display \
#                    @expo-google-fonts/dm-sans \
#                    @expo-google-fonts/dm-mono
#
#   # Copy .env and fill in your Supabase URL + anon key
#   cp .env .env.local

# ── 3. Database: add push_token column ───────────────────────────────
#
# Run this in Supabase SQL Editor:
#
#   ALTER TABLE public.profiles ADD COLUMN IF NOT EXISTS push_token text;
#
# This stores each device's Expo push token so the server can send
# targeted push notifications via Expo's Push API.

# ── 4. Run locally ───────────────────────────────────────────────────
#
#   npx expo start
#   # Press 'i' for iOS simulator, 'a' for Android emulator
#   # Scan QR with Expo Go app on physical device for push notif testing

# ── 5. EAS setup and first build ────────────────────────────────────
#
#   eas login                          # your Expo account
#   eas build:configure                # creates eas.json if not present
#
#   # Replace YOUR_EAS_PROJECT_ID in app.json with the project ID shown after:
#   eas project:init
#
#   # Development build (installs on device, supports push notifs)
#   eas build --profile development --platform ios
#   eas build --profile development --platform android
#
#   # Production build
#   eas build --profile production --platform all

