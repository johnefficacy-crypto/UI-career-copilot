# ── 7. Onboarding on mobile ───────────────────────────────────────────
#
# Full onboarding (multi-step profile setup) is web-only.
# The mobile app redirects unonboarded users to the web URL:
#
#   import { Linking } from "react-native"
#   Linking.openURL("https://careercopilot.in/onboarding")
#
# This is the simplest path for v1. A native onboarding flow can be
# added in a future phase once the web onboarding is stable.

# ── 8. Signing up on mobile ───────────────────────────────────────────
#
# Create app/(auth)/signup.tsx mirroring login.tsx but calling signUp().
# After signUp, redirect to onboarding (web) since profile setup is
# too complex for the mobile MVP. The user returns to the app after
# completing onboarding on web — deep link: careercopilot://dashboard

# ── 9. Sharing auth state between web and mobile ─────────────────────
#
# Both apps connect to the same Supabase project.
# Auth sessions are NOT shared (web uses HTTP-only cookies, mobile uses
# AsyncStorage). Users sign in separately on each platform — this is
# the correct and secure approach.

# ── 10. App Store / Play Store submission ────────────────────────────
#
#   eas submit --platform ios      # submits to App Store Connect
#   eas submit --platform android  # submits to Google Play Console
#
# Checklist before submission:
#   ✓ App icons provided (1024×1024 for iOS, adaptive for Android)
#   ✓ Splash screen assets in assets/images/
#   ✓ Push notification entitlements configured in app.json
#   ✓ google-services.json added for Android (from Firebase console)
#   ✓ Replace YOUR_EAS_PROJECT_ID in app.json
#   ✓ Set real bundleIdentifier and package in app.json
#   ✓ Privacy policy URL live at careercopilot.in/privacy

# ── 11. Feature parity summary ───────────────────────────────────────
#
# ✅ Dashboard         — Exam targets, active plan widget, recent alerts
# ✅ Study planner     — Week cards, expand/collapse, status updates, log session
# ✅ Forum             — Browse, search, filter by category, upvote, compose, reply
# ✅ Notifications     — All alerts, auto mark-as-read, urgency colours
# ✅ Profile           — User info, notification toggles, plan badge, sign out
# ✅ Push notifications — Deadline reminders (7d, 3d, 1d), daily streak nudge
# ✅ Auth              — Sign in, sign out, session persistence via AsyncStorage
# ✅ Deep linking      — Notification tap routes to correct tab
# ⬜ AI Career Chat    — Phase 8 (web only for now; streaming complex on mobile)
# ⬜ Marketplace       — Phase 6 (payment flows complex on mobile, web redirect)
# ⬜ Admin panel       — Web only (admin tasks require full desktop interface)